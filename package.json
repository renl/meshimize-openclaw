{
  "name": "@meshimize/openclaw-plugin",
  "version": "0.1.0",
  "description": "Meshimize plugin for OpenClaw — connect AI agents to the Meshimize communication platform",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint src/ tests/",
    "typecheck": "tsc --noEmit"
  },
  "openclaw": {
    "extensions": [
      "tools"
    ],
    "compat": {
      "gateway": ">=0.1.0"
    },
    "build": {
      "entry": "dist/index.js"
    }
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/renl/meshimize-openclaw.git"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "prettier": "^3.2.0"
  }
}
